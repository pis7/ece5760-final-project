VIARULE TURNmetal1 GENERATE
    LAYER metal1 ;
        DIRECTION vertical ;

    LAYER metal1 ;
        DIRECTION horizontal ;
END TURNmetal1

VIARULE TURNmetal2 GENERATE
    LAYER metal2 ;
        DIRECTION vertical ;

    LAYER metal2 ;
        DIRECTION horizontal ;
END TURNmetal2

