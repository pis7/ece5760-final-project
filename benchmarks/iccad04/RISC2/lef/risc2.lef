VIA via1 DEFAULT
    RESISTANCE 6.000 ;
    LAYER metal1 ;
        RECT -0.120 -0.160 0.120 0.160 ;
    LAYER V1 ;
        RECT -0.100 -0.100 0.100 0.100 ;
    LAYER metal2 ;
        RECT -0.100 -0.100 0.100 0.100 ;
END via1

