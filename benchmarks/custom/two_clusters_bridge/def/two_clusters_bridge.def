VERSION 5.4 ;
NAMESCASESENSITIVE ON ;
DIVIDERCHAR "/" ;
BUSBITCHARS "[]" ;
DESIGN two_clusters_bridge ;
UNITS DISTANCE MICRONS 100 ;

DIEAREA ( 0 0 ) ( 500 500 ) ;

COMPONENTS 32 ;
- A1 CELL + PLACED ( 30 30 ) N ;
- A2 CELL + PLACED ( 70 30 ) N ;
- A3 CELL + PLACED ( 110 30 ) N ;
- A4 CELL + PLACED ( 150 30 ) N ;
- A5 CELL + PLACED ( 30 70 ) N ;
- A6 CELL + PLACED ( 70 70 ) N ;
- A7 CELL + PLACED ( 110 70 ) N ;
- A8 CELL + PLACED ( 150 70 ) N ;
- A9 CELL + PLACED ( 30 110 ) N ;
