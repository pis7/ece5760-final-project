VERSION 5.4 ;
NAMESCASESENSITIVE ON ;
DIVIDERCHAR "/" ;
BUSBITCHARS "[]" ;
DESIGN mixed_macro_10 ;
UNITS DISTANCE MICRONS 100 ;

DIEAREA ( 0 0 ) ( 187.5 125 ) ;

COMPONENTS 10 ;
- U1 INV + PLACED ( 6.25 6.25 ) N ;
- U2 INV + PLACED ( 25 6.25 ) N ;
- U3 AND2 + PLACED ( 43.75 6.25 ) N ;
- U4 OR2 + PLACED ( 68.75 6.25 ) N ;
- U5 WIDE + PLACED ( 93.75 6.25 ) N ;
- U6 INV + PLACED ( 12.5 37.5 ) N ;
- U7 AND2 + PLACED ( 31.25 37.5 ) N ;
- U8 OR2 + PLACED ( 56.25 37.5 ) N ;
- U9 INV + PLACED ( 81.25 37.5 ) N ;
- U10 WIDE + PLACED ( 106.25 37.5 ) N ;
END COMPONENTS

PINS 8 ;
- a + NET a + DIRECTION INPUT + USE SIGNAL + PLACED ( 0 12.5 ) N ;
- b + NET b + DIRECTION INPUT + USE SIGNAL + PLACED ( 0 37.5 ) N ;
- c + NET c + DIRECTION INPUT + USE SIGNAL + PLACED ( 0 62.5 ) N ;
- d + NET d + DIRECTION INPUT + USE SIGNAL + PLACED ( 0 87.5 ) N ;
- w + NET w + DIRECTION OUTPUT + USE SIGNAL + PLACED ( 187.5 12.5 ) N ;
- x + NET x + DIRECTION OUTPUT + USE SIGNAL + PLACED ( 187.5 37.5 ) N ;
- y + NET y + DIRECTION OUTPUT + USE SIGNAL + PLACED ( 187.5 62.5 ) N ;
- z + NET z + DIRECTION OUTPUT + USE SIGNAL + PLACED ( 187.5 87.5 ) N ;
END PINS

NETS 14 ;
- a ( PIN a ) ( U1 A ) ( U3 A ) ;
- b ( PIN b ) ( U2 A ) ( U3 B ) ;
- c ( PIN c ) ( U6 A ) ( U7 A ) ;
- d ( PIN d ) ( U7 B ) ( U8 B ) ;
- n1 ( U1 Y ) ( U4 A ) ;
- n2 ( U2 Y ) ( U4 B ) ;
- n3 ( U3 Y ) ( U5 A ) ;
- n4 ( U4 Y ) ( U5 B ) ;
- n5 ( U6 Y ) ( U8 A ) ;
- n6 ( U7 Y ) ( U9 A ) ( U10 A ) ;
- n7 ( U8 Y ) ( U10 B ) ;
- w ( PIN w ) ( U5 Y ) ;
- x ( PIN x ) ( U9 Y ) ;
- y ( PIN y ) ( U10 Y ) ;
END NETS

END DESIGN
