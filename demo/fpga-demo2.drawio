 + beta * d             &lt;br&gt;        rr     = rr_new&lt;br&gt;    end &lt;span class=&quot;hljs-keyword&quot; style=&quot;color: rgb(86, 156, 214);&quot;&gt;for&lt;/span&gt; &lt;/code&gt;&lt;/pre&gt;" vertex="1">
